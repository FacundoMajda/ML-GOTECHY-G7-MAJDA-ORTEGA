# .env — variables de entorno para Video Analytics Platform
# Copiar este archivo a .env y completar los valores
#
# Para desarrollo local con Docker (docker-compose.yml):
#   NEON_DB_URL=postgresql://videoanalytics:videoanalytics@db:5432/video_analytics
#
# Para desarrollo local sin Docker:
#   NEON_DB_URL=postgresql://user:pass@localhost:5432/video_analytics

NEON_DB_URL=
YOLO_MODEL_PATH=yolo11n.pt
OUTPUT_DIR=outputs
REPORTS_DIR=reports
UPLOADS_DIR=uploads
